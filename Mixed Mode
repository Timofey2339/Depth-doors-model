local LatestRoom = game.ReplicatedStorage.GameData.LatestRoom

-- ======================
-- SPAWN SYSTEM
-- ======================
local function spawnAfterDelay(delayTime, url)
    coroutine.wrap(function()
        while true do
            LatestRoom:GetPropertyChangedSignal("Value"):Wait()
            task.wait(0)
            task.wait(delayTime)
            load(url)
        end
    end)()
end
